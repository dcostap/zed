// Personal fork keymap.
// Best-effort JetBrains/VS Code-style bindings tuned for Dario's workflow.
// Some shortcuts may be transformed before Zed sees them by AutoHotkey.
[
  {
    "context": "Workspace",
    "bindings": {
      // Editing / intelligence
      "ctrl-space": "editor::ShowCompletions",
      "ctrl-q": "editor::Hover",
      "ctrl-shift-p": "command_palette::Toggle",
      "ctrl-p": "editor::ShowSignatureHelp",
      "ctrl-s": "workspace::Save",
      "ctrl-shift-s": "workspace::SaveAs",
      "alt-shift-f": "editor::Format",
      "alt-enter": "editor::ToggleCodeActions",
      "ctrl-/": "editor::ToggleComments",
      "ctrl-d": "editor::DuplicateLineDown",
      "f2": "editor::Rename",
      "ctrl-g": null,
      "ctrl-shift-g": null,
      "ctrl-o": null,
      "ctrl-i": null,
      "ctrl-alt-v": null,
      "ctrl-alt-f": null,
      "ctrl-alt-p": null,
      "ctrl-alt-t": "workspace::NewTerminal",
      "ctrl-x": "editor::Cut",
      "ctrl-k": "editor::DeleteToEndOfLine",
      "shift-enter": "editor::NewlineBelow",
      "ctrl-enter": "editor::NewlineBelow",
      "ctrl-n": "editor::MoveLineUp",
      "ctrl-m": "editor::MoveLineDown",
      "ctrl-alt-n": "editor::AddSelectionAbove",
      "ctrl-alt-m": "editor::AddSelectionBelow",
      "alt-p": "editor::SelectNext",
      "alt-shift-p": "editor::SelectEnclosingSymbol",
      "alt-shift-o": "editor::SelectLargerSyntaxNode",
      "alt-shift-u": "editor::SelectSmallerSyntaxNode",
      "alt-u": "editor::Backspace",
      "alt-o": "editor::Delete",
      "ctrl-alt-o": "editor::SelectToNextSubwordEnd",
      "ctrl-alt-u": "editor::SelectToPreviousSubwordStart",
      "alt-a": "task::Spawn",
      "alt-s": "debugger::Start",
      "alt-d": null,
      "alt-f": "debugger::Stop",
      "ctrl-.": "editor::ShowEditPrediction",
      "ctrl-alt-z": "editor::GoToHunk",

      // Navigation / search
      "ctrl-shift-a": "command_palette::Toggle",
      "ctrl-j": "outline::Toggle",
      "ctrl-shift-j": "project_symbols::Toggle",
      "ctrl-shift-d": "go_to_line::Toggle",
      "ctrl-e": "file_finder::Toggle",
      "ctrl-shift-e": "projects::OpenRecent",
      "alt-z": "pane::ActivatePreviousItem",
      "alt-x": "pane::ActivateNextItem",
      "alt-w": "editor::GoToHunk",
      "ctrl--": "editor::Fold",
      "ctrl-=" : "editor::UnfoldLines",
      "ctrl-shift--": "editor::FoldAll",
      "ctrl-shift-=" : "editor::UnfoldAll",
      "ctrl-tab": "pane::AlternateFile",
      "ctrl-shift-n": "workspace::NewFile",
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-ñ": "pane::ActivateNextItem",
      "ctrl-alt-j": "pane::GoBack",
      "ctrl-alt-l": "pane::GoForward",
      "alt-g": null,
      "ctrl-alt-.": "editor::GoToNextChange",
      "ctrl-alt-,": "editor::GoToPreviousHunk",
      "ctrl-alt-h": "editor::MoveToBeginning",
      "ctrl-alt-ñ": "editor::MoveToEnd",
      "ctrl-alt-shift-h": "editor::SelectToBeginning",
      "ctrl-alt-shift-ñ": "editor::SelectToEnd",
      "ctrl-alt-i": "editor::MoveToStartOfParagraph",
      "ctrl-alt-k": "editor::MoveToEndOfParagraph",
      "ctrl-alt-shift-i": "editor::SelectToStartOfParagraph",
      "ctrl-alt-shift-k": "editor::SelectToEndOfParagraph",
      "alt-r": "editor::GoToDefinition",
      "alt-shift-r": "editor::FindAllReferences",
      "ctrl-alt-r": "editor::GoToTypeDefinition",
      "ctrl-shift-l": "editor::RevealInFileManager",
      "ctrl-l": "pane::RevealInProjectPanel",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-shift-f": "project_search::ToggleFocus",
      "f1": "editor::GoToDiagnostic",
      "alt-shift-q": "editor::GoToPreviousDiagnostic",
      "alt-shift-w": "editor::GoToDiagnostic",
      "f6": "debugger::StepOut",
      "f7": "debugger::StepOver",
      "f8": "debugger::StepInto",
      "alt-8": "search::SelectPreviousMatch",
      "alt-9": "search::SelectNextMatch",
      "ctrl-w": ["pane::CloseActiveItem", { "close_pinned": false }],
      "ctrl-t": "workspace::NewFile",
      "ctrl-shift-w": ["pane::CloseOtherItems", { "close_pinned": false }],
      "ctrl-shift-t": "pane::ReopenClosedItem",
      "alt-1": "workspace::ToggleAllDocks",
      "alt-shift-1": "workspace::FocusCenterPane",
      "alt-2": "project_panel::ToggleFocus",
      "alt-3": "terminal_panel::Toggle",
      "alt-4": "debug_panel::ToggleFocus",
      "ctrl-0": "pane::SplitRight",
      "ctrl-8": "workspace::ActivatePreviousPane",
      "ctrl-9": "workspace::ActivateNextPane",
      "ctrl-shift-i": "agent::Chat",
      "ctrl-1": "workspace::ActivatePaneLeft",
      "ctrl-2": "workspace::ActivateNextPane",
      "ctrl-3": "workspace::ActivateNextPane",
      "shift-escape": "workspace::CloseActiveDock",
      "alt-c": "git_panel::ToggleFocus",

      // Pending / explicit no-ops to avoid surprise defaults
      "alt-shift-e": null,
      "ctrl-,": null,
      "ctrl-alt-shift-p": null,
      "ctrl-shift-o": null,
      "ctrl-shift-space": null,
      "ctrl-shift-enter": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-space": "editor::ShowCompletions",
      "ctrl-q": "editor::Hover",
      "ctrl-p": "editor::ShowSignatureHelp",
      "ctrl-s": "workspace::Save",
      "ctrl-shift-s": "workspace::SaveAs",
      "alt-shift-f": "editor::Format",
      "alt-enter": "editor::ToggleCodeActions",
      "ctrl-/": "editor::ToggleComments",
      "ctrl-d": "editor::DuplicateLineDown",
      "f2": "editor::Rename",
      "ctrl-x": "editor::Cut",
      "ctrl-k": "editor::DeleteToEndOfLine",
      "shift-enter": "editor::NewlineBelow",
      "ctrl-enter": "editor::NewlineBelow",
      "ctrl-n": "editor::MoveLineUp",
      "ctrl-m": "editor::MoveLineDown",
      "ctrl-alt-n": "editor::AddSelectionAbove",
      "ctrl-alt-m": "editor::AddSelectionBelow",
      "alt-p": "editor::SelectNext",
      "alt-shift-p": "editor::SelectEnclosingSymbol",
      "alt-shift-o": "editor::SelectLargerSyntaxNode",
      "alt-shift-u": "editor::SelectSmallerSyntaxNode",
      "alt-u": "editor::Backspace",
      "alt-o": "editor::Delete",
      "ctrl-alt-o": "editor::SelectToNextSubwordEnd",
      "ctrl-alt-u": "editor::SelectToPreviousSubwordStart",
      "ctrl-.": "editor::ShowEditPrediction",
      "ctrl-j": "outline::Toggle",
      "ctrl-shift-j": "project_symbols::Toggle",
      "ctrl-shift-d": "go_to_line::Toggle",
      "ctrl-e": "file_finder::Toggle",
      "alt-z": "pane::ActivatePreviousItem",
      "alt-x": "pane::ActivateNextItem",
      "ctrl--": "editor::Fold",
      "ctrl-=" : "editor::UnfoldLines",
      "ctrl-shift--": "editor::FoldAll",
      "ctrl-shift-=" : "editor::UnfoldAll",
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-ñ": "pane::ActivateNextItem",
      "ctrl-alt-j": "pane::GoBack",
      "ctrl-alt-l": "pane::GoForward",
      "ctrl-alt-.": "editor::GoToNextChange",
      "ctrl-alt-,": "editor::GoToPreviousHunk",
      "ctrl-alt-h": "editor::MoveToBeginning",
      "ctrl-alt-ñ": "editor::MoveToEnd",
      "ctrl-alt-shift-h": "editor::SelectToBeginning",
      "ctrl-alt-shift-ñ": "editor::SelectToEnd",
      "ctrl-alt-i": "editor::MoveToStartOfParagraph",
      "ctrl-alt-k": "editor::MoveToEndOfParagraph",
      "ctrl-alt-shift-i": "editor::SelectToStartOfParagraph",
      "ctrl-alt-shift-k": "editor::SelectToEndOfParagraph",
      "alt-r": "editor::GoToDefinition",
      "alt-shift-r": "editor::FindAllReferences",
      "ctrl-alt-r": "editor::GoToTypeDefinition",
      "ctrl-shift-l": "editor::RevealInFileManager",
      "ctrl-l": "pane::RevealInProjectPanel",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-shift-f": "project_search::ToggleFocus",
      "f1": "editor::GoToDiagnostic",
      "alt-shift-q": "editor::GoToPreviousDiagnostic",
      "alt-shift-w": "editor::GoToDiagnostic",
      "ctrl-w": ["pane::CloseActiveItem", { "close_pinned": false }],
      "ctrl-t": "workspace::NewFile",
      "ctrl-shift-w": ["pane::CloseOtherItems", { "close_pinned": false }],
      "ctrl-shift-t": "pane::ReopenClosedItem",
      "ctrl-shift-i": "agent::Chat",
      "ctrl-shift-space": null,
      "ctrl-shift-enter": null,
      "ctrl-g": null,
      "ctrl-shift-g": null,
      "ctrl-o": null,
      "ctrl-i": null,
      "ctrl-alt-v": null,
      "ctrl-alt-f": null,
      "ctrl-alt-p": null,
      "ctrl-alt-t": null,
      "alt-g": null,
      "alt-shift-e": null,
      "ctrl-,": null,
      "ctrl-shift-o": null
    }
  },
  {
    "context": "SearchBar || BufferSearchBar || ProjectSearch",
    "bindings": {
      "alt-enter": "search::ToggleSelection",
      "ctrl-enter": "search::ReplaceAll",
      "alt-8": "search::SelectPreviousMatch",
      "alt-9": "search::SelectNextMatch"
    }
  },
  {
    "context": "menu",
    "bindings": {
      "ctrl-enter": "menu::Confirm",
      "alt-enter": "menu::SecondaryConfirm"
    }
  }
]
